# Sync API (Fastify + MongoDB)
#
# P1 WPN (Mongo source of truth, read-only): authenticated GET routes mirror headless
# `/api/v1/wpn/*` shapes but without `/api/v1` prefix:
#   GET /wpn/workspaces
#   GET /wpn/workspaces/:workspaceId/projects
#   GET /wpn/projects/:projectId/notes
#   GET /wpn/notes-with-context
#   GET /wpn/backlinks/:noteId
#   GET /wpn/projects/:projectId/explorer-state
#   GET /wpn/notes/:id
#   GET /wpn/all-notes-list   (all projects, same row shape as per-project notes list)
# Collections: wpn_workspaces, wpn_projects, wpn_notes, wpn_explorer_state
#
# P2 writes (same auth): POST/PATCH/DELETE /wpn/workspaces, /wpn/projects, /wpn/notes,
# /wpn/notes/move, /wpn/notes/delete, explorer-state PATCH, /wpn/*/settings, duplicate subtree, …
PORT=4010
HOST=0.0.0.0
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=nodex_sync
JWT_SECRET=change-me-minimum-32-characters-long!!
CORS_ORIGIN=true
