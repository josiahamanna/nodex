# Sync API (Fastify + MongoDB)
#
# All HTTP handlers (except root `GET /health` for probes) are mounted under `/api/v1`:
#   POST /api/v1/auth/register, /api/v1/auth/login, …
#   GET/POST/PATCH/DELETE /api/v1/wpn/…
#   GET/PUT /api/v1/me/shell-layout, …
#   GET /api/v1/public/bundled-docs/…
# Collections: wpn_workspaces, wpn_projects, wpn_notes, wpn_explorer_state
#
# MongoDB Atlas: set MONGODB_URI to your mongodb+srv://… string (password only in this file or secret store; never commit real secrets).
PORT=4010
HOST=0.0.0.0
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=nodex_sync
JWT_SECRET=change-me-minimum-32-characters-long!!
CORS_ORIGIN=true
