{
  "name": "@nodex/sync-api",
  "private": true,
  "version": "0.0.0",
  "description": "Fastify + MongoDB sync API (proposed-architecture ADR-003/005)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build:shared": "tsc --outDir ../../src/shared --rootDir ../../src/shared --target ES2022 --module commonjs --moduleResolution node --declaration false --skipLibCheck --esModuleInterop ../../src/shared/note-vfs-link-rewrite.ts ../../src/shared/note-vfs-path.ts ../../src/shared/markdown-internal-note-href.ts ../../src/shared/wpn-v2-types.ts",
    "build:lib": "npm run build:shared && tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "start": "NODE_ENV=production tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/integration-auth-wpn.test.ts src/integration-org-invites.test.ts src/integration-spaces.test.ts src/integration-teams.test.ts src/integration-visibility-acl.test.ts src/integration-project-acl.test.ts src/integration-announcements.test.ts src/integration-audit.test.ts src/mcp-device-auth.test.ts src/marked-smoke.test.ts src/repo-bundled-docs-path.test.ts src/refresh-sessions.test.ts",
    "seed:wpn": "tsx scripts/seed-wpn-demo.ts"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@fastify/multipart": "^10.0.0",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "marked": "^15.0.12",
    "mongodb": "^6.12.0",
    "unzipper": "^0.12.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/unzipper": "^0.10.11",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
