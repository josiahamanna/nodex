{
  "name": "@nodex/sync-api",
  "private": true,
  "version": "0.0.0",
  "description": "Fastify + MongoDB sync API (proposed-architecture ADR-003/005)",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build:lib": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/server.ts",
    "start": "NODE_ENV=production tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/integration-auth-wpn.test.ts src/mcp-device-auth.test.ts src/marked-smoke.test.ts src/repo-bundled-docs-path.test.ts src/refresh-sessions.test.ts",
    "seed:wpn": "tsx scripts/seed-wpn-demo.ts"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "dotenv": "^16.4.7",
    "@fastify/cors": "^11.0.0",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "marked": "^15.0.12",
    "mongodb": "^6.12.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
