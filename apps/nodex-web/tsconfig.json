{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@nodex/ui-types": ["../../src/shared/nodex-preload-public-types.ts"]
    }
  },
  "include": [
    "next-env.d.ts",
    "nodex-globals.d.ts",
    "../../src/types/window.d.ts",
    "../../src/types/observable-runtime.d.ts",
    "../../src/types/observable-inspector.d.ts",
    "../../src/types/observable-stdlib.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
