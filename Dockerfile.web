# Web UI container (Next.js) for docker-compose.
# Runs `next start` on port 3000 after building the workspace app.
#
# Default: cloud WPN via sync-api — browser uses NEXT_PUBLIC_NODEX_SYNC_API_URL (e.g. gateway :8080).

FROM node:22-bookworm-slim

WORKDIR /app

ARG NEXT_PUBLIC_NODEX_API_SAME_ORIGIN=0
ENV NEXT_PUBLIC_NODEX_API_SAME_ORIGIN=${NEXT_PUBLIC_NODEX_API_SAME_ORIGIN}

ARG NEXT_PUBLIC_NODEX_WPN_USE_SYNC_API=1
ENV NEXT_PUBLIC_NODEX_WPN_USE_SYNC_API=${NEXT_PUBLIC_NODEX_WPN_USE_SYNC_API}

ARG NEXT_PUBLIC_NODEX_WEB_BACKEND=sync-only
ENV NEXT_PUBLIC_NODEX_WEB_BACKEND=${NEXT_PUBLIC_NODEX_WEB_BACKEND}

# Public sync API base (no trailing slash). Match gateway origin + `/api/v1` (default :8080).
ARG NEXT_PUBLIC_NODEX_SYNC_API_URL=http://127.0.0.1:8080/api/v1
ENV NEXT_PUBLIC_NODEX_SYNC_API_URL=${NEXT_PUBLIC_NODEX_SYNC_API_URL}

# CI/agents often see transient registry errors (e.g. ECONNRESET); npm retries reduce flake.
ENV npm_config_fetch_retries=5 \
    npm_config_fetch_retry_mintimeout=20000 \
    npm_config_fetch_retry_maxtimeout=120000

COPY package.json package-lock.json ./
COPY apps ./apps
COPY src ./src
COPY tsconfig.json ./

RUN npm ci --ignore-scripts \
  && npm run build -w @nodex/web \
  && npm prune --omit=dev

ENV NODE_ENV=production

EXPOSE 3000

CMD ["npm", "run", "start", "-w", "@nodex/web"]
