# Monorepo single env file (repo root). Copy to `.env` and edit; never commit `.env`.
# Docker Compose and `scripts/docker-*.sh` read this path. Next + sync-api load it in dev (see below).
#
# --- Local npm (web + sync-api only; skips slow electron-rebuild on `npm install`) ---
# NODEX_SKIP_ELECTRON_REBUILD=1
# Or once: `npm run install:web` / `npm run ci:web`. Electron: `npm run rebuild:electron`
#
# --- Electron ADR-016 (local RxDB mirror + optional renderer authority) ---
# Mirror: after each main `nodex-workspace.json` persist, main pushes a debounced payload to the renderer;
# renderer hydrates RxDB snapshot + normalized WPN collections and can serve WPN reads via `getNodex()` overlay.
# NODEX_LOCAL_RXDB_WPN=1
# Authority: main `WorkspaceStore.persist()` no-ops; renderer must call `Nodex.flushWorkspaceRxdbMirrorToDisk(payload)`
# with the same v1 mirror shape (set in main process env when launching Electron).
# NODEX_WORKSPACE_RXDB_AUTHORITY=1
#
# --- Docker / deploy (Compose interpolates ${VAR} from this file) ---
# Local mongo container: omit when MONGODB_URI points at remote DB (not *mongo-sync*); deploy defaults NODEX_LOCAL_MONGO=0 then.
# Force compose Mongo anyway: NODEX_LOCAL_MONGO=1
# NODEX_LOCAL_MONGO=0
# MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.example.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=nodex_sync
# JWT_SECRET=minimum-32-characters-for-production-signing-key
# NODEX_GATEWAY_PORT=8080
# COMPOSE_PROJECT_NAME=nodex
#
# --- sync-api (local `npm run sync-api` and defaults when not overridden by Compose) ---
# PORT=4010
# HOST=0.0.0.0
# MONGODB_URI=mongodb://127.0.0.1:27017
# MONGODB_DB=nodex_sync
# JWT_SECRET=change-me-minimum-32-characters-long
# CORS_ORIGIN=true
#
# --- Next web (`npm run dev:web` / Dockerfile.web build args; use NEXT_PUBLIC_* only) ---
# Sync client calls paths like `/auth/register` relative to this base — it must end with `/api/v1`
# (e.g. `http://127.0.0.1:4010/api/v1`). A bare `http://127.0.0.1:4010` yields 404 on `/auth/register`.
# NEXT_PUBLIC_NODEX_SYNC_API_URL=http://127.0.0.1:4010/api/v1
# NEXT_PUBLIC_NODEX_SYNC_API_URL=http://127.0.0.1:8080/api/v1
# NEXT_PUBLIC_NODEX_WPN_USE_SYNC_API=1
# NEXT_PUBLIC_NODEX_WEB_BACKEND=sync-only
# Force sync client to use the browser tab origin + /api/v1 (nginx gateway on same host).
# NEXT_PUBLIC_NODEX_API_SAME_ORIGIN=1
# If unset: opening a non-loopback host (e.g. nodex.studio) while NEXT_PUBLIC_NODEX_SYNC_API_URL
# still points at 127.0.0.1/localhost is auto-corrected to same-origin /api/v1 in the client.
# NEXT_PUBLIC_NODEX_API_SAME_ORIGIN=0
#
# --- Electron file vault (Track A legacy removal) ---
# When 1, `WorkspaceStore.persist` writes empty `legacy` and note IPC skips flat-store fallbacks (WPN-only on disk).
# NODEX_WPN_ONLY_FILE_VAULT=1
# Set to 0 to skip automatic legacy flat tree → WPN migration on eligible project open (default: migrate when eligible).
# NODEX_MIGRATE_LEGACY_FLAT_TO_WPN=0
