# Monorepo single env file (repo root). Copy to `.env` and edit; never commit `.env`.
# Docker Compose and `scripts/docker-*.sh` read this path. Next + sync-api load it in dev (see below).
#
# --- Local npm (web + sync-api only; skips slow electron-rebuild on `npm install`) ---
# NODEX_SKIP_ELECTRON_REBUILD=1
# Or once: `npm run install:web` / `npm run ci:web`. Electron: `npm run rebuild:electron`
#
# --- Docker / deploy (Compose interpolates ${VAR} from this file) ---
# Local mongo container: omit when MONGODB_URI points at remote DB (not *mongo-sync*); deploy defaults NODEX_LOCAL_MONGO=0 then.
# Force compose Mongo anyway: NODEX_LOCAL_MONGO=1
# NODEX_LOCAL_MONGO=0
# MONGODB_URI=mongodb+srv://USER:PASS@CLUSTER.example.mongodb.net/?retryWrites=true&w=majority
# MONGODB_DB=nodex_sync
# JWT_SECRET=minimum-32-characters-for-production-signing-key
# NODEX_GATEWAY_PORT=8080
# COMPOSE_PROJECT_NAME=nodex
#
# --- sync-api (local `npm run sync-api` and defaults when not overridden by Compose) ---
# PORT=4010
# HOST=0.0.0.0
# MONGODB_URI=mongodb://127.0.0.1:27017
# MONGODB_DB=nodex_sync
# JWT_SECRET=change-me-minimum-32-characters-long
# CORS_ORIGIN=true
#
# --- Next web (`npm run dev:web` / Dockerfile.web build args; use NEXT_PUBLIC_* only) ---
# Base URL must include `/api/v1` (no trailing slash).
# NEXT_PUBLIC_NODEX_SYNC_API_URL=http://127.0.0.1:4010/api/v1
# NEXT_PUBLIC_NODEX_SYNC_API_URL=http://127.0.0.1:8080/api/v1
# NEXT_PUBLIC_NODEX_WPN_USE_SYNC_API=1
# NEXT_PUBLIC_NODEX_WEB_BACKEND=sync-only
# NEXT_PUBLIC_NODEX_API_SAME_ORIGIN=0
