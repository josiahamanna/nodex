# Local Drone + GitHub (see docker-compose.drone.yml at repo root).
# Copy to deploy/drone/.env (gitignored):
#   npm run drone:init
# Edit this file, then: npm run drone:up
#
# --- 1) RPC secret (server + runner must match) ---
#   openssl rand -hex 16
DRONE_RPC_SECRET=replace-with-openssl-rand-hex-16

# --- 2) How Drone advertises itself (OAuth redirect + GitHub webhooks) ---
# Local browser only:
DRONE_SERVER_PROTO=http
DRONE_SERVER_HOST=localhost:8888
#
# If you use a public tunnel so GitHub can deliver webhooks, set these to the tunnel URL, e.g.:
# DRONE_SERVER_PROTO=https
# DRONE_SERVER_HOST=your-subdomain.ngrok-free.app
# and use the same host in the GitHub OAuth callback below.

# --- 3) GitHub OAuth App (for Drone login + repo access) ---
# GitHub → Settings → Developer settings → OAuth Apps → New OAuth App
#   Application name: Drone (local)
#   Homepage URL:      http://localhost:8888   (or your tunnel https URL)
#   Callback URL:      http://localhost:8888/login   (must match DRONE_SERVER_*)
# Copy Client ID and generate a client secret:
DRONE_GITHUB_CLIENT_ID=
DRONE_GITHUB_CLIENT_SECRET=

# --- Webhooks ---
# With localhost only, automatic “build on push” will not work; start builds from the Drone UI
# or point a tunnel at port 8888 and recreate the OAuth app + Drone env with the public hostname.

# --- Optional ---
# DRONE_HTTP_PORT=8888
# DRONE_RUNNER_METRICS_PORT=9393
